+
+def _init_overlap_scale_ewm_state(
+    states: int,
+    *,
+    max_alpha: float,
+    decay_alpha: float,
+    window_size: int | None = None,
+    dtype=jnp.float32,
+) -> OverlapScaleEWMState:
+  """Initialise DeepQMC-style EWM buffers for overlap-gradient scaling."""
+
+  if window_size is None:
+    window_size = math.ceil(decay_alpha * (1.0 / (1.0 - max_alpha) - 2.0))
+  window_size = max(1, int(window_size))
+  return OverlapScaleEWMState(
+      step=0,
+      alpha=jnp.zeros((window_size,), dtype=dtype),
+      energy_buffer=jnp.zeros((window_size, states), dtype=dtype),
+      std_buffer=jnp.zeros((window_size, states), dtype=dtype),
+      energy_mean=jnp.full((states,), jnp.nan, dtype=dtype),
+      std_mean=jnp.full((states,), jnp.nan, dtype=dtype),
+  )
+
+
+def _deepqmc_ewm_update(
+    value: jnp.ndarray,
+    buffer: jnp.ndarray,
+    alpha: jnp.ndarray,
+    step: int,
+    *,
+    max_alpha: float,
+    decay_alpha: float,
+) -> tuple[jnp.ndarray, jnp.ndarray]:
+  """DeepQMC EWM update used for automatic overlap-gradient scaling."""
+
+  value = jnp.asarray(value, dtype=buffer.dtype)
+  buffer = jnp.concatenate([value[None], buffer[:-1]], axis=0)
+  new_alpha = jnp.maximum(
+      jnp.asarray(1.0 - max_alpha, dtype=buffer.dtype),
+      jnp.asarray(1.0 / (2.0 + step / decay_alpha), dtype=buffer.dtype))
+  if step + 1 < alpha.shape[0]:
+    alpha = jnp.concatenate([new_alpha[None], alpha[:-1]], axis=0)
+  beta = jnp.concatenate(
+      [jnp.ones((1,), dtype=alpha.dtype), jnp.cumprod(1.0 - alpha[:-1])],
+      axis=0)
+  weights = alpha * beta
+  mean = jnp.sum(weights[:, None] * buffer, axis=0)
+  return buffer, mean
+
+
+def _update_overlap_scale_ewm(
+    aux_data: qmc_loss_functions.AuxiliaryLossData,
