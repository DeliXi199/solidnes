+      positions=positions, spins=pmap_spins, atoms=atoms, charges=charges
+  )
+
+  logging.info(
+      'Starting PBC HF pretraining: iterations=%d target_backend=%s '
+      'target_chunk_size=%d log_every=%d',
+      iterations, getattr(scf_approx, 'target_backend', 'pyscf_pbc'),
+      target_chunk_size, log_every)
+  for t in range(iterations):
+    step_start_time = time.perf_counter()
