+class OverlapScaleEWMState(NamedTuple):
+  step: int
+  alpha: jnp.ndarray
+  energy_buffer: jnp.ndarray
+  std_buffer: jnp.ndarray
+  energy_mean: jnp.ndarray
+  std_mean: jnp.ndarray
