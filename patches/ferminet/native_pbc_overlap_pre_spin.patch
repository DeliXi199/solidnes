+      target_eval_seconds = time.perf_counter() - target_eval_start_time
+
+      target_transfer_start_time = time.perf_counter()
+      target = tuple(jnp.asarray(tar) for tar in target)
+      _block_until_ready(target)
+      target_transfer_seconds = time.perf_counter() - target_transfer_start_time
+
+    sharded_key, subkeys = kfac_jax.utils.p_split(sharded_key)
+    jax_update_start_time = time.perf_counter()
+    data, params, opt_state_pt, loss, pmove = pretrain_step(
+        data, target, params, opt_state_pt, subkeys)
+    _block_until_ready((loss, pmove))
+    jax_update_seconds = time.perf_counter() - jax_update_start_time
+    step_seconds = time.perf_counter() - step_start_time
+
+    loss_scalar = float(loss[0])
+    pmove_scalar = float(pmove[0])
+    if log_every and (t % log_every == 0 or t == iterations - 1):
+      logging.info(
+          'PBC pretrain iter %05d: loss=%g pmove=%g '
+          'step_seconds=%.6f target_eval_seconds=%.6f '
+          'target_transfer_seconds=%.6f jax_update_seconds=%.6f',
+          t, loss_scalar, pmove_scalar, step_seconds, target_eval_seconds,
+          target_transfer_seconds, jax_update_seconds)
+    if stats_writer:
+      stats_writer.write(
+          t,
+          loss=loss_scalar,
+          pmove=pmove_scalar,
+          step_seconds=step_seconds,
+          target_eval_seconds=target_eval_seconds,
+          target_transfer_seconds=target_transfer_seconds,
+          jax_update_seconds=jax_update_seconds)
+      if log_every and (t % log_every == 0 or t == iterations - 1):
