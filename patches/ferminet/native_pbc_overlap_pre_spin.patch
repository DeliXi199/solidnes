+):
+  """Pretrains FermiNet PBC orbitals against a PySCF PBC HF target."""
+
+  target_chunk_size = int(target_chunk_size or 0)
+  log_every = int(log_every or 0)
+  if target_chunk_size < 0:
+    raise ValueError(
+        f'target_chunk_size must be non-negative, got {target_chunk_size}')
+  if log_every < 0:
+    raise ValueError(f'log_every must be non-negative, got {log_every}')
+
+  optimizer = optax.adam(learning_rate)
+  opt_state_pt = constants.pmap(optimizer.init)(params)
+
+  pretrain_step = make_pbc_pretrain_step(
+      batch_orbitals,
