+def _np_enforce_pbc(latvec: np.ndarray, epos: np.ndarray):
+  """Wrap Cartesian coordinates into the PySCF cell and return cell shifts."""
+  dim = latvec.shape[-1]
+  epos = epos.reshape([-1, dim])
+  fractional = np.einsum('ij,jk->ik', epos, np.linalg.inv(latvec))
+  wrap, wrapped_fractional = np.divmod(fractional, 1)
+  return np.matmul(wrapped_fractional, latvec).ravel(), wrap
+
