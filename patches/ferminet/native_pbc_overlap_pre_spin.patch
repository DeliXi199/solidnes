+    translations = wrap @ self.cell.a
+    phase = np.exp(1j * np.einsum('kd,nd->kn', self.kpts, translations))
+    ao_by_k = [ao_k * phase[k][:, None] for k, ao_k in enumerate(ao_by_k)]
+    return np.stack(ao_by_k, axis=0).reshape(
+        [len(self.kpts), batch, nelec, -1])
+
+  def eval_mos_pbc(self, aos: np.ndarray, spin: int) -> np.ndarray:
+    """Project periodic atomic orbitals into occupied molecular orbitals."""
+    coeff_key = self.coeff_key[spin]
+    coeffs_by_k = np.split(
+        self.parameters[coeff_key], self.param_split[coeff_key], axis=-1)
+    mos = [
+        aos[k].dot(coeffs_by_k[k])
+        for k in range(len(self.kpts))
+        if coeffs_by_k[k].shape[-1] > 0
+    ]
+    return np.concatenate(mos, axis=-1)
+
+  def eval_orbitals(
+      self,
+      pos: Union[np.ndarray, jnp.ndarray],
+      nspins: Tuple[int, int],
+      target_chunk_size: int = 0,
+  ) -> Tuple[np.ndarray, np.ndarray]:
+    """Evaluate occupied PBC HF orbital matrices at electron positions."""
+    pos = np.asarray(pos, dtype=np.float64)
+    leading_dims = pos.shape[:-1]
+    nelec = sum(nspins)
+    coord = pos.reshape([-1, nelec, self.ndim])
+    target_chunk_size = int(target_chunk_size or 0)
+    if target_chunk_size < 0:
+      raise ValueError(
+          f'target_chunk_size must be non-negative, got {target_chunk_size}')
+    if target_chunk_size:
+      walker_chunk_size = max(1, target_chunk_size // nelec)
+    else:
+      walker_chunk_size = coord.shape[0]
+
+    result_by_spin = [[], []]
+    for chunk_start in range(0, coord.shape[0], walker_chunk_size):
+      chunk = coord[chunk_start:chunk_start + walker_chunk_size]
+      aos = self.eval_orbitals_pbc(chunk)
+      for spin in (0, 1):
+        ne = int(nspins[spin])
+        if ne == 0:
+          result_by_spin[spin].append(np.zeros((chunk.shape[0], 0, 0)))
+          continue
+        start = 0 if spin == 0 else int(nspins[0])
+        stop = start + ne
+        mo = self.eval_mos_pbc(aos[:, :, start:stop], spin)
+        result_by_spin[spin].append(mo.reshape((chunk.shape[0], ne, ne)))
+
+    result = []
+    for spin in (0, 1):
+      ne = int(nspins[spin])
+      spin_result = np.concatenate(result_by_spin[spin], axis=0)
+      result.append(spin_result.reshape(leading_dims + (ne, ne)))
+    return tuple(result)
+
+  def eval_slater(
+      self,
+      pos: Union[jnp.ndarray, np.ndarray],
+      nspins: Tuple[int, int],
+  ) -> Tuple[jnp.ndarray, jnp.ndarray]:
+    """Evaluate the PBC HF Slater determinant."""
+    matrices = self.eval_orbitals(pos, nspins)
+    sign = 1.0
+    log_abs = 0.0
+    for matrix in matrices:
+      if matrix.shape[-1] == 0:
+        continue
+      matrix_sign, matrix_log_abs = jnp.linalg.slogdet(matrix)
+      sign = sign * matrix_sign
+      log_abs = log_abs + matrix_log_abs
+    return sign, log_abs
