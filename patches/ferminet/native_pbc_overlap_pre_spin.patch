+def _symmetrized_squared_overlap(overlap: jnp.ndarray) -> jnp.ndarray:
+  """Returns S_ij^2 from non-symmetric overlap estimates.
+
+  This follows the Szabo-Noe/DeepQMC clipped-geometric estimator: the signed
+  square root is not needed for the penalty, so this helper returns the clipped
+  product directly.
+  """
+
+  return jnp.maximum(overlap * jnp.swapaxes(overlap, -1, -2), 0.0)
+
+
+def _symmetrized_overlap(overlap: jnp.ndarray) -> jnp.ndarray:
+  """Returns the signed clipped-geometric overlap estimator."""
+
+  return jnp.sign(overlap) * jnp.sqrt(_symmetrized_squared_overlap(overlap))
+
+
+def _clip_overlap_ratios(
+    overlap_ratio: jnp.ndarray,
+    clip_width: float,
+    exclude_width: float,
+) -> tuple[jnp.ndarray, jnp.ndarray]:
+  """Median-clip overlap ratios and return a gradient mask.
+
+  Clipping is pairwise over the walker/device sample axis, matching the
+  DeepQMC psi-ratio clipping idea.  The forward overlap value is still computed
+  from the unclipped ratios; clipped ratios only affect the custom-JVP tangent.
+  """
+
+  if clip_width <= 0.0 and exclude_width == float('inf'):
+    return overlap_ratio, jnp.ones_like(overlap_ratio, dtype=bool)
+  all_ratios = constants.all_gather(overlap_ratio).real
+  flat_ratios = all_ratios.reshape((-1,) + all_ratios.shape[-2:])
+  center = jnp.median(flat_ratios, axis=0)
+  deviation = jnp.abs(overlap_ratio - center)
+  flat_deviation = jnp.abs(flat_ratios - center)
+  sigma = jnp.median(flat_deviation, axis=0)
+  clipped = jnp.clip(
+      overlap_ratio,
+      center - clip_width * sigma,
+      center + clip_width * sigma)
+  mask = deviation < exclude_width
+  return clipped, mask
+
+
+def _masked_centered_overlap_diff(
+    clipped_overlap: jnp.ndarray,
+    ratio_gradient_mask: jnp.ndarray,
+) -> jnp.ndarray:
+  """Centers clipped overlap ratios and applies a samplewise gradient mask."""
+
+  clipped_mean = constants.pmean(jnp.mean(clipped_overlap, axis=0))
+  centered = clipped_overlap - clipped_mean
+  mask = ratio_gradient_mask.astype(clipped_overlap.dtype)
+  mask_fraction = constants.pmean(jnp.mean(mask, axis=0))
+  safe_weight = jnp.where(mask_fraction > 0, mask / mask_fraction, 0.0)
+  return centered * safe_weight
+
+
+def _overlap_gradient_scale(
