+def pretrain_hartree_fock_pbc(
+    *,
+    params: networks.ParamTree,
+    positions: jnp.ndarray,
+    spins: jnp.ndarray,
+    atoms: jnp.ndarray,
+    charges: jnp.ndarray,
+    batch_network: networks.FermiNetLike,
+    batch_orbitals: networks.OrbitalFnLike,
+    network_options: networks.BaseNetworkOptions,
+    sharded_key: chex.PRNGKey,
+    electrons: Tuple[int, int],
+    scf_approx: PbcScf,
+    iterations: int = 1000,
+    batch_size: int = 0,
+    logger: Callable[[int, float], None] | None = None,
+    learning_rate: float = 3.e-4,
+    mcmc_steps: int = 1,
+):
+  """Pretrains FermiNet PBC orbitals against a PySCF PBC HF target."""
+
+  optimizer = optax.adam(learning_rate)
+  opt_state_pt = constants.pmap(optimizer.init)(params)
+
+  pretrain_step = make_pbc_pretrain_step(
+      batch_orbitals,
+      batch_network,
+      optimizer.update,
+      electrons=electrons,
+      batch_size=batch_size,
+      full_det=network_options.full_det,
+      ndim=network_options.ndim,
+      mcmc_steps=mcmc_steps,
+  )
+  pretrain_step = constants.pmap(pretrain_step)
+
+  batch_spins = jnp.tile(spins[None], [positions.shape[1], 1])
+  pmap_spins = kfac_jax.utils.replicate_all_local_devices(batch_spins)
+  data = networks.FermiNetData(
+      positions=positions, spins=pmap_spins, atoms=atoms, charges=charges
+  )
+
+  for t in range(iterations):
+    target = scf_approx.eval_orbitals(np.asarray(data.positions), electrons)
+    target = tuple(jnp.asarray(tar) for tar in target)
+    sharded_key, subkeys = kfac_jax.utils.p_split(sharded_key)
+    data, params, opt_state_pt, loss, pmove = pretrain_step(
+        data, target, params, opt_state_pt, subkeys)
+    logging.info('PBC pretrain iter %05d: %g %g', t, loss[0], pmove[0])
+    if logger:
+      logger(t, loss[0])
+  return params, data.positions
