+def make_pbc_pretrain_step(
+    batch_orbitals: networks.OrbitalFnLike,
+    batch_network: networks.LogFermiNetLike,
+    optimizer_update: optax.TransformUpdateFn,
+    electrons: Tuple[int, int],
+    batch_size: int = 0,
+    full_det: bool = False,
+    ndim: int = 3,
+    mcmc_steps: int = 1,
+):
+  """Creates one PBC HF orbital-pretraining step.
+
+  Unlike molecular HF pretraining, PySCF PBC orbitals are evaluated on the host
+  and provided as a fixed target. The compiled step only differentiates the
+  network orbital MSE and refreshes walkers with the neural wavefunction.
+  """
+
+  del electrons  # Shape is carried by the target matrices.
+  mcmc_step = mcmc.make_mcmc_step(
+      batch_network, batch_per_device=batch_size, steps=mcmc_steps, ndim=ndim)
+
+  def loss_fn(
+      params: networks.ParamTree,
+      data: networks.FermiNetData,
+      target: Tuple[jnp.ndarray, jnp.ndarray],
+  ):
+    orbitals = batch_orbitals(
+        params, data.positions, data.spins, data.atoms, data.charges)
+    cnorm = lambda x, y: (x - y) * jnp.conj(x - y)
+    if full_det:
+      dims = target[0].shape[:-2]
+      na = target[0].shape[-2]
+      nb = target[1].shape[-2]
+      dtype = jnp.promote_types(target[0].dtype, target[1].dtype)
+      target_full = jnp.concatenate(
+          (
+              jnp.concatenate(
+                  (
+                      target[0].astype(dtype),
+                      jnp.zeros(dims + (na, nb), dtype=dtype),
+                  ),
+                  axis=-1,
+              ),
+              jnp.concatenate(
+                  (
+                      jnp.zeros(dims + (nb, na), dtype=dtype),
+                      target[1].astype(dtype),
+                  ),
+                  axis=-1,
+              ),
+          ),
+          axis=-2,
+      )
+      result = jnp.mean(cnorm(target_full[:, None, ...], orbitals[0])).real
+    else:
+      result = jnp.array([
+          jnp.mean(cnorm(t[:, None, ...], o)).real
+          for t, o in zip(target, orbitals)
+          if t.shape[-1] > 0
+      ]).sum()
+    return constants.pmean(result)
+
+  def pretrain_step(data, target, params, state, key):
+    val_and_grad = jax.value_and_grad(loss_fn, argnums=0)
+    loss_val, search_direction = val_and_grad(params, data, target)
+    search_direction = constants.pmean(search_direction)
+    updates, state = optimizer_update(search_direction, state, params)
+    params = optax.apply_updates(params, updates)
+    data, pmove = mcmc_step(params, data, key, width=0.02)
+    return data, params, state, loss_val, pmove
+
+  return pretrain_step
+
