+def get_pbc_hf(
+    molecule: Sequence[system.Atom],
+    nspins: Tuple[int, int],
+    lattice: np.ndarray,
+    basis: str = 'ccpvdz',
+    pseudo: str | Mapping[str, str] | None = None,
+    twist: Sequence[float] | None = None,
+    precision: float = 1e-8,
+    exp_to_discard: float = 0.1,
+    restricted: bool = True,
+    pyscf_cell: Any | None = None,
+) -> 'PbcScf':
+  """Returns a periodic PySCF Hartree-Fock solution for PBC pretraining.
+
+  The molecular pretraining path uses a JAX-native GTO evaluator inside the
+  compiled pretraining step. PySCF PBC orbital evaluation is not JAX-native, so
+  the PBC route follows DeepSolid: evaluate the HF target matrices on the host
+  once per pretraining iteration and pass those fixed targets into the pmapped
+  update step.
+  """
+  scf_approx = PbcScf(
+      molecule=molecule,
+      nspins=nspins,
+      lattice=lattice,
+      basis=basis,
+      pseudo=pseudo,
+      twist=twist,
+      precision=precision,
+      exp_to_discard=exp_to_discard,
+      restricted=restricted,
+      pyscf_cell=pyscf_cell,
+  )
+  scf_approx.run()
+  return scf_approx
+
+
+class PbcScf:
+  """Small PySCF PBC HF wrapper used as an orbital pretraining target."""
+
+  def __init__(
+      self,
+      molecule: Sequence[system.Atom],
+      nspins: Tuple[int, int],
+      lattice: np.ndarray,
+      basis: str = 'ccpvdz',
+      pseudo: str | Mapping[str, str] | None = None,
+      twist: Sequence[float] | None = None,
+      precision: float = 1e-8,
+      exp_to_discard: float = 0.1,
+      restricted: bool = True,
+      pyscf_cell: Any | None = None,
+  ):
+    from pyscf.pbc import gto as pbc_gto  # pylint: disable=import-outside-toplevel
+    from pyscf.pbc import scf as pbc_scf  # pylint: disable=import-outside-toplevel
+
+    self.nspins = tuple(int(x) for x in nspins)
+    self.restricted = restricted
+    self.ndim = 3
+    if pyscf_cell is None:
+      cell = pbc_gto.Cell()
+      cell.atom = [[atom.symbol, atom.coords] for atom in molecule]
+      # FermiNet PBC configs use lattice vectors as columns; PySCF stores them
+      # as rows.
+      cell.a = np.asarray(lattice, dtype=np.float64).T
+      cell.unit = 'B'
+      cell.basis = basis
+      if pseudo:
+        cell.pseudo = pseudo
+      cell.spin = self.nspins[0] - self.nspins[1]
+      cell.verbose = 0
+      cell.precision = float(precision)
+      cell.exp_to_discard = float(exp_to_discard)
+      cell.build()
+    else:
+      cell = pyscf_cell.copy()
+      cell.verbose = 0
+      if not cell._built:  # pylint: disable=protected-access
+        cell.build()
+    if cell.nelectron != sum(self.nspins):
+      raise RuntimeError(
+          'PySCF PBC cell is not consistent with QMC electron count: '
+          f'cell.nelectron={cell.nelectron}, nspins={self.nspins}'
+      )
+
+    self.cell = cell
+    twist = np.zeros(3) if twist is None else np.asarray(twist, dtype=np.float64)
+    if twist.shape != (3,):
+      raise ValueError(f'Expected a 3-vector twist, got shape {twist.shape}')
+    self.twist = np.mod(twist, 1.0)
+    self.kpts = np.asarray([self.twist @ self.cell.reciprocal_vectors()])
+
+    if restricted:
+      khf_cls = getattr(pbc_scf, 'KHF', pbc_scf.KRHF)
+      self.mean_field = khf_cls(self.cell, exxdiv='ewald', kpts=self.kpts)
+    else:
+      self.mean_field = pbc_scf.KUHF(
+          self.cell, exxdiv='ewald', kpts=self.kpts)
+    self.mean_field = self.mean_field.density_fit()
+    self.coeff_key = ('mo_coeff_alpha', 'mo_coeff_beta')
+    self.param_split = {}
+    self.parameters = {}
+    self.k_split = {}
+
+  def run(self):
+    """Run PySCF PBC HF and cache occupied MO coefficients."""
+    dm0 = self.mean_field.get_init_guess()
+    self.mean_field.kernel(dm0)
+    if not self.mean_field.converged:
+      logging.warning('PySCF PBC HF did not report convergence.')
+    self._init_orbital_coefficients()
+
+  def _init_orbital_coefficients(self):
+    """Collect occupied MO coefficients for each spin and k point."""
+    mo_coeff = self.mean_field.mo_coeff
+    mo_occ = self.mean_field.mo_occ
+    try:
+      unrestricted_coeff = len(mo_coeff[0][0].shape) == 2
+    except (IndexError, TypeError):
+      unrestricted_coeff = False
+
+    for spin, key in enumerate(self.coeff_key):
+      coeffs = []
+      k_counts = []
+      for k in range(len(self.kpts)):
+        if unrestricted_coeff:
+          occ = np.asarray(mo_occ[spin][k]) > 0.9
+          coeff = np.asarray(mo_coeff[spin][k])[:, occ]
+        else:
+          min_occ = (0.9, 1.1)[spin]
+          occ = np.asarray(mo_occ[k]) > min_occ
+          coeff = np.asarray(mo_coeff[k])[:, occ]
+        coeffs.append(coeff)
+        k_counts.append(coeff.shape[1])
+      total_orbitals = sum(k_counts)
+      if total_orbitals != self.nspins[spin]:
+        raise RuntimeError(
+            'PBC HF occupied-orbital count does not match spin count: '
+            f'spin={spin}, occupied={total_orbitals}, expected={self.nspins[spin]}'
+        )
+      self.param_split[key] = np.cumsum(k_counts)[:-1]
+      self.parameters[key] = np.concatenate(coeffs, axis=-1)
+      self.k_split[key] = np.asarray(k_counts)
+
+  def eval_orbitals_pbc(self, coord: np.ndarray) -> np.ndarray:
+    """Evaluate periodic atomic orbitals for all k points."""
+    batch, nelec, ndim = coord.shape
+    if ndim != self.ndim:
+      raise ValueError(f'Only ndim={self.ndim} is supported, got {ndim}')
+    wrapped, wrap = _np_enforce_pbc(self.cell.a, coord.reshape([-1, ndim]))
+    wrapped = wrapped.reshape([-1, ndim])
+    wrap = wrap.reshape([-1, ndim])
+    ao = self.cell.eval_gto('PBCGTOval_sph', wrapped, kpts=self.kpts)
+    if isinstance(ao, np.ndarray) and ao.ndim == 2:
+      ao_by_k = [ao]
+    elif isinstance(ao, np.ndarray):
+      ao_by_k = [ao[k] for k in range(ao.shape[0])]
+    else:
+      ao_by_k = list(ao)
+    translations = wrap @ self.cell.a
+    phase = np.exp(1j * np.einsum('kd,nd->kn', self.kpts, translations))
+    ao_by_k = [ao_k * phase[k][:, None] for k, ao_k in enumerate(ao_by_k)]
+    return np.stack(ao_by_k, axis=0).reshape(
+        [len(self.kpts), batch, nelec, -1])
+
+  def eval_mos_pbc(self, aos: np.ndarray, spin: int) -> np.ndarray:
+    """Project periodic atomic orbitals into occupied molecular orbitals."""
+    coeff_key = self.coeff_key[spin]
+    coeffs_by_k = np.split(
+        self.parameters[coeff_key], self.param_split[coeff_key], axis=-1)
+    mos = [
+        aos[k].dot(coeffs_by_k[k])
+        for k in range(len(self.kpts))
+        if coeffs_by_k[k].shape[-1] > 0
+    ]
+    return np.concatenate(mos, axis=-1)
+
+  def eval_orbitals(
+      self,
+      pos: Union[np.ndarray, jnp.ndarray],
+      nspins: Tuple[int, int],
+  ) -> Tuple[jnp.ndarray, jnp.ndarray]:
+    """Evaluate occupied PBC HF orbital matrices at electron positions."""
+    pos = np.asarray(pos, dtype=np.float64)
+    leading_dims = pos.shape[:-1]
+    nelec = sum(nspins)
+    coord = pos.reshape([-1, nelec, self.ndim])
+    aos = self.eval_orbitals_pbc(coord)
+    result = []
+    for spin in (0, 1):
+      ne = int(nspins[spin])
+      if ne == 0:
+        result.append(jnp.zeros(leading_dims + (0, 0)))
+        continue
+      start = 0 if spin == 0 else int(nspins[0])
+      stop = start + ne
+      mo = self.eval_mos_pbc(aos[:, :, start:stop], spin)
+      result.append(jnp.asarray(mo.reshape(leading_dims + (ne, ne))))
+    return tuple(result)
+
+  def eval_slater(
+      self,
+      pos: Union[jnp.ndarray, np.ndarray],
+      nspins: Tuple[int, int],
+  ) -> Tuple[jnp.ndarray, jnp.ndarray]:
+    """Evaluate the PBC HF Slater determinant."""
+    matrices = self.eval_orbitals(pos, nspins)
+    sign = 1.0
+    log_abs = 0.0
+    for matrix in matrices:
+      if matrix.shape[-1] == 0:
+        continue
+      matrix_sign, matrix_log_abs = jnp.linalg.slogdet(matrix)
+      sign = sign * matrix_sign
+      log_abs = log_abs + matrix_log_abs
+    return sign, log_abs
+
+
+def _np_enforce_pbc(latvec: np.ndarray, epos: np.ndarray):
+  """Wrap Cartesian coordinates into the PySCF cell and return cell shifts."""
+  dim = latvec.shape[-1]
+  epos = epos.reshape([-1, dim])
+  fractional = np.einsum('ij,jk->ik', epos, np.linalg.inv(latvec))
+  wrap, wrapped_fractional = np.divmod(fractional, 1)
+  return np.matmul(wrapped_fractional, latvec).ravel(), wrap
+
