+def _diagonal_spin_contributions(spin_local: jnp.ndarray) -> jnp.ndarray:
+  """Return the per-sample per-state S^2 contributions.
+
+  The FermiNet S^2 observable can return a batched full state matrix for
+  excited-state calculations.  DeepQMC's spin penalty is evaluated on the state
+  sampled by each chain, so the loss-level penalty consumes only the diagonal
+  entries.  A rank-2 ``[batch, states]`` array is already diagonal/state-specific
+  and must not be treated as a square matrix when ``batch == states``.
+  """
+
+  spin_local = jnp.asarray(spin_local)
+  if spin_local.ndim >= 3 and spin_local.shape[-1] == spin_local.shape[-2]:
+    return jnp.diagonal(spin_local, axis1=-2, axis2=-1)
+  return spin_local
+
+
+def _deepqmc_spin_penalty_terms(
+    spin_local: jnp.ndarray,
+    spin_penalty: float,
+) -> tuple[jnp.ndarray, jnp.ndarray, jnp.ndarray]:
+  """Return DeepQMC-style spin penalty loss and JVP coefficients.
+
+  DeepQMC adds ``beta * <S^2>`` to the scalar loss, where ``<S^2>`` is the
+  equal average over electronic states and samples.  Its custom JVP adds the
+  score-function tangent of this expectation, i.e. per-state centered local
+  S^2 contributions with the same final state average.  The coefficient
+  returned here has shape ``[batch, states]`` and can be added to the existing
+  diagonal log-wavefunction tangent coefficients.
+  """
+
+  spin_diag = _diagonal_spin_contributions(spin_local).real
+  if spin_diag.ndim == 0:
+    spin_by_state = constants.pmean(spin_diag)
+    spin_mean = spin_by_state
+    spin_diff = spin_diag - spin_by_state
+    state_weight = jnp.asarray(1.0, dtype=spin_diag.dtype)
+  else:
+    spin_by_state = constants.pmean(jnp.mean(spin_diag, axis=0))
+    spin_mean = jnp.mean(spin_by_state)
+    spin_diff = spin_diag - spin_by_state
+    state_weight = jnp.asarray(1.0 / spin_diag.shape[-1], dtype=spin_diag.dtype)
+  penalty = jnp.asarray(spin_penalty, dtype=spin_diag.dtype)
+  return penalty * spin_mean, penalty * state_weight * spin_diff, spin_by_state
+
+
