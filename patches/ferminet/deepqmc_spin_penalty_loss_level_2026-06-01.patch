index 30f15c0..0511f84 100644
--- a/ferminet/observables.py
+++ b/ferminet/observables.py
@@ -227,6 +227,79 @@ def make_s2(
   return s2_estimator


+def make_deepqmc_state_s2(
+    signed_network: networks.FermiNetLike,
+    nspins: Tuple[int, ...],
+    assign_spin: bool = True,
+    states: int = 0,
+    state_specific_network: Optional[Callable[..., Tuple[jnp.ndarray, jnp.ndarray]]] = None,
+) -> Observable:
+  """Evaluates DeepQMC-style per-state local S^2 contributions.
+
+  ``make_s2(..., states=n)`` returns a full observable matrix using the native
+  FermiNet excited-state matrix estimator.  DeepQMC's spin penalty instead uses
+  the local spin estimator for each state's own sampled walkers.  This helper
+  returns the diagonal/state-specific vector with shape ``[states]`` for one
+  batchless excited-state configuration, matching DeepQMC's
+  ``evaluate_spin`` logic.
+  """
+
+  if states <= 0:
+    raise ValueError('DeepQMC-style state S^2 requires states > 0')
+  if not assign_spin:
+    raise NotImplementedError('DeepQMC-style excited-state S^2 is only '
+                              'implemented for spin-assigned wavefunctions')
+
+  def s2_estimator(
+      params: networks.ParamTree,
+      data: networks.FermiNetData,
+      state: None = None,
+  ) -> jnp.ndarray:
+    """Returns one local S^2 contribution per excited state."""
+    del state
+
+    if sum(nspins) == 1:
+      return jnp.full((states,), 0.75)
+
+    na, nb = sorted(nspins, reverse=True)
+    base_s2 = (na - nb) / 2 * ((na - nb) / 2 + 1) + nb
+    positions = jnp.reshape(data.positions, (states, -1))
+    spins = jnp.reshape(data.spins, (states, -1))
+
+    def evaluate_state(state_idx: int) -> jnp.ndarray:
+      pos = positions[state_idx]
+      spin = spins[state_idx]
+
+      def eval_network(pos_):
+        if state_specific_network is not None:
+          return state_specific_network(
+              params, state_idx, pos_, spin, data.atoms, data.charges)
+        sign_all, log_all = signed_network(
+            params, pos_, spin, data.atoms, data.charges)
+        return sign_all[state_idx], log_all[state_idx]
+
+      sign_psi, log_psi = eval_network(pos)
+      xa, xb = jnp.split(
+          jnp.reshape(pos, (sum(nspins), -1)), nspins[:1], axis=-2)
+
+      def _inner(ib, val):
+        ia, s2 = val
+        xx = xa.at[ia].set(xb[ib]), xb.at[ib].set(xa[ia])
+        xx = jnp.reshape(jnp.concatenate(xx, axis=0), -1)
+        sign_swap, log_swap = eval_network(xx)
+        s2 -= sign_psi * sign_swap * jnp.exp(log_swap - log_psi)
+        return ia, s2
+
+      def _outer(ia, s2):
+        return jax.lax.fori_loop(0, nspins[1], _inner, (ia, s2))[1]
+
+      return jax.lax.fori_loop(0, nspins[0], _outer, base_s2)
+
+    return jnp.stack([evaluate_state(state_idx) for state_idx in range(states)])
+
+  return s2_estimator
+
+
